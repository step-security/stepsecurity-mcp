# StepSecurity API key — generate one from the StepSecurity dashboard.
# Sent as `Authorization: Bearer <key>` on every upstream call.
STEP_SECURITY_API_KEY=

# Your StepSecurity customer/tenant identifier. When set, tools that accept
# a `customer` arg fall back to this value if the caller omits it. Set this
# so you don't have to retype your tenant on every prompt.
STEP_SECURITY_CUSTOMER=

# Optional: log level (debug | info | warn | error). Defaults to info.
# Logs go to stderr so they don't corrupt the stdio JSON-RPC stream.
LOG_LEVEL=info
